# Exemplo de configuração para MongoDB Atlas
NODE_ENV='development'

# Para MongoDB Atlas - substitua pelos seus dados reais
MONGO_CONNECTION_STRING='mongodb+srv://seu-usuario:sua-senha@seu-cluster.mongodb.net/seu-database?retryWrites=true&w=majority'

# Opcional: Se quiser especificar um authSource diferente (padrão é 'admin')
# MONGO_AUTH_SOURCE='admin'

# ===== CONFIGURAÇÃO ALTERNATIVA PARA MONGODB LOCAL =====
# Se estiver usando MongoDB local ao invés do Atlas, comente a linha MONGO_CONNECTION_STRING
# e descomente as linhas abaixo:

# MONGO_HOST='localhost'
# MONGO_PORT='27017'
# MONGO_DATABASE='seu-database'
# MONGO_USER='seu-usuario'
# MONGO_PASSWORD='sua-senha'
# MONGO_AUTH_SOURCE='admin'