NODE_ENV='development'

# ===== CONFIGURAÇÃO DO SERVIDOR =====
PORT=3001

# ===== CONFIGURAÇÃO MONGODB =====
# URL completa de conexão MongoDB (local ou remoto)
# Exemplos:
# Local: mongodb://admin:password@localhost:27017/nrc_database?authSource=admin
# Railway: mongodb://mongo:password@mongohost.railway.internal:27017/railway?authSource=admin
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
MONGO_URL='mongodb://admin:password@localhost:27017/nrc_database?authSource=admin'

# ===== CONFIGURAÇÃO QDRANT =====
# Para Qdrant local: localhost
# Para Qdrant no Railway: apenas o host (sem porta), ex: qdrant-dev-fc94.up.railway.app
QDRANT_HOST='localhost'
QDRANT_PORT='6333'
# API key é opcional - deixe vazio se não tiver
QDRANT_API_KEY=''

# ===== CONFIGURAÇÃO JWT =====
JWT_EXPIRES_IN='7d'
JWT_SECRET='your_jwt_secret_key'

# ===== USUÁRIO ADMIN PADRÃO =====
# Credenciais do usuário administrador criado automaticamente
ADMIN_NAME='Administrador'
ADMIN_EMAIL='admin@nrctools.com'
ADMIN_PASSWORD='admin123'