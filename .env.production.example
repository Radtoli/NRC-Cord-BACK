# Configuração de Produção para NRC Tools Backend
# ATENÇÃO: Nunca commite este arquivo com dados reais!

NODE_ENV=production
PORT=3001

# ===== CONFIGURAÇÃO CORS =====
# Domínios permitidos para requisições CORS (separados por vírgula)
CORS_ORIGINS=https://nrc-coord-front-dev.up.railway.app,https://nrc-coord-front.vercel.app

# ===== MONGODB PRODUÇÃO =====
# Exemplo para MongoDB Atlas
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/nrc_database?retryWrites=true&w=majority

# Exemplo para Railway MongoDB
# MONGO_URL=mongodb://mongo:password@mongohost.railway.internal:27017/railway?authSource=admin

# ===== QDRANT PRODUÇÃO =====
# Qdrant Cloud ou servidor dedicado
QDRANT_HOST=your-qdrant-cluster.qdrant.io
QDRANT_PORT=6333
QDRANT_API_KEY=your-qdrant-api-key

# ===== JWT PRODUÇÃO =====
# Use uma chave longa e complexa para produção!
JWT_SECRET=your_super_strong_and_long_jwt_secret_key_for_production_environment_2024
JWT_EXPIRES_IN=7d

# ===== USUÁRIO ADMIN =====
# Credenciais do usuário administrador padrão
ADMIN_NAME=Administrador Sistema
ADMIN_EMAIL=admin@suaempresa.com
ADMIN_PASSWORD=SenhaForteESeguranParaProducao123!

# ===== CONFIGURAÇÕES OPCIONAIS =====
# Configurações adicionais para produção
LOG_LEVEL=info
MAX_UPLOAD_SIZE=10mb
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=15